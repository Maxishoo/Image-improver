# 1. Берем готовую коробку с Node.js
FROM node:24-alpine

# 2. Создаем папку для проекта внутри коробки
WORKDIR /app

# 3. Копируем файлы зависимостей (package.json)
COPY package*.json ./

# 4. Устанавливаем библиотеки внутри коробки
RUN npm install

# 5. Копируем весь остальной код проекта
COPY . .

# 6. Открываем порт 5173 (порт Vite)
EXPOSE 5173

# 7. Запускаем режим разработки
CMD ["npm", "run", "dev"]